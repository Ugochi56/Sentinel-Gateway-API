# Copy this to .env and fill in your values.
# Never commit .env to git.

# Supabase — project URL and anon/service key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# RapidAPI — the proxy secret shown in your RapidAPI dashboard
# (Settings → Security → Proxy Secret)
RAPIDAPI_PROXY_SECRET=your-rapidapi-proxy-secret

# Your Render deploy URL (used to build the /hooks/{id} proxy URL returned at registration)
BASE_URL=https://sentinel-gateway.onrender.com

# ── Optional tuning (defaults shown) ──────────────────────────

# Reject payloads larger than this (bytes). Default: 1 MB.
MAX_PAYLOAD_SIZE_BYTES=1000000

# Max retry attempts before marking an event as failed_permanently.
MAX_RETRIES=5

# How often the delivery worker polls Supabase (seconds).
WORKER_POLL_INTERVAL_SECONDS=10

# HTTP timeout for outbound delivery requests (seconds).
DELIVERY_TIMEOUT_SECONDS=15

# Max events processed per worker tick.
WORKER_BATCH_SIZE=10

# Delete delivered events older than N days (keeps Supabase under 500 MB free cap).
CLEANUP_DELIVERED_AFTER_DAYS=7
